Options -Indexes
DirectoryIndex public/index.html

RewriteEngine On

RewriteRule ^api/(.*)$ api.php [QSA,L]
RewriteRule ^app/?$ public/index.html [L]
RewriteRule ^app\.js$ public/app.js [L]
RewriteRule ^styles\.css$ public/styles.css [L]
RewriteRule ^logo\.jpg$ public/logo.jpg [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ public/index.html [L]

<FilesMatch "^(config\.php|.*\.json)$">
  Require all denied
</FilesMatch>
