PORT=3010
APP_BASE_URL=http://localhost:3010
APP_NAME=Choir Private Area
APP_SECRET=change-this-long-random-string

# Ghost Admin API integration.
GHOST_API_URL=https://your-ghost-site.example
GHOST_ADMIN_API_KEY=admin-key-id:admin-key-secret
GHOST_ACCESS_LABEL=cantante

# Comma-separated admin emails. Admins can see all attendance and edit content.
ADMIN_EMAILS=tu-email@example.com

# Development helper. When true, missing Ghost config does not block login.
DEV_AUTH=true

# Production email sending. Resend is the recommended default.
# If these are empty, magic links are only printed in the server logs.
EMAIL_PROVIDER=resend
RESEND_API_KEY=
MAIL_FROM=Ars Mvsica <acceso@tu-dominio.example>

# Optional alternative: Mailgun.
# Set EMAIL_PROVIDER=mailgun if you prefer this provider.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Use https://api.eu.mailgun.net for EU domains.
MAILGUN_BASE_URL=https://api.mailgun.net
